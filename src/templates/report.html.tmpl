<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>${title}</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 2rem auto; max-width: 1100px; line-height: 1.5; color: #1f2937; }
    h1, h2, h3 { color: #111827; }
    .meta { color: #4b5563; margin-bottom: 1.5rem; }
    .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; margin: 1.5rem 0; }
    .card { border: 1px solid #d1d5db; border-radius: 8px; padding: 1rem; background: #f9fafb; }
    .label { font-size: 0.85rem; color: #6b7280; }
    .value { font-size: 1.25rem; font-weight: 700; margin-top: 0.3rem; }
    pre { white-space: pre-wrap; word-break: break-word; background: #f3f4f6; padding: 1rem; border-radius: 8px; border: 1px solid #e5e7eb; }
    ul { padding-left: 1.25rem; }
  </style>
</head>
<body>
  <header>
    <h1>${title}</h1>
    <div class="meta">
      <div><strong>Topic:</strong> ${topic}</div>
      <div><strong>Goal:</strong> ${goal}</div>
      <div><strong>Strategy:</strong> ${strategy_name}</div>
      <div><strong>Status:</strong> ${run_status}</div>
      <div><strong>Started:</strong> ${started_at}</div>
      <div><strong>Completed:</strong> ${completed_at}</div>
    </div>
  </header>

  <section>
    <h2>Run Summary</h2>
    <div class="grid">${summary_cards_html}</div>
  </section>

  <section>
    <h2>Dimensions Explored</h2>
    <ul>${dimensions_html}</ul>
  </section>

  <section>
    <h2>Methods</h2>
    <pre>${methods_text}</pre>
  </section>

  <section>
    <h2>Synthesis</h2>
    <pre>${synthesis_text}</pre>
  </section>

  <section>
    <h2>Evidence Quality</h2>
    <pre>${evidence_quality_text}</pre>
  </section>

  <section>
    <h2>Rubric</h2>
    <pre>${rubric_text}</pre>
  </section>

  ${semantic_html}
  ${dashboard_html}
  ${evaluation_html}
  ${comparison_html}
</body>
</html>
