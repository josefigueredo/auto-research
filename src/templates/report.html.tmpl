<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>${title}</title>
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
  <style>
${main_css}
  </style>
  <style media="print">
${print_css}
  </style>
</head>
<body>
  ${header_html}

  <section>
    <h2>Run Summary</h2>
    <div class="grid">${summary_cards_html}</div>
  </section>

  <section>
    <h2>Dimensions Explored</h2>
    <ul>${dimensions_html}</ul>
  </section>

  <section>
    <h2>Methods</h2>
    <div class="markdown-body" id="methods-content"></div>
  </section>

  <section>
    <h2>Synthesis</h2>
    <div class="markdown-body" id="synthesis-content"></div>
  </section>

  <section>
    <h2>Evidence Quality</h2>
    <div class="json-view" id="evidence-quality-content"></div>
  </section>

  <section>
    <h2>Rubric</h2>
    <div class="json-view" id="rubric-content"></div>
  </section>

  ${semantic_html}
  ${semantic_review_html}
  ${dashboard_html}
  ${evaluation_html}
  ${comparison_html}

  <script>
    // --- Embedded data (generated by reporting.py) ---
    var METHODS_RAW = ${methods_json};
    var SYNTHESIS_RAW = ${synthesis_json};
    var EVIDENCE_QUALITY_DATA = ${evidence_quality_json};
    var RUBRIC_DATA = ${rubric_json};

    // --- Markdown rendering ---
    function renderMarkdown(elementId, rawText) {
      var el = document.getElementById(elementId);
      if (el && rawText) {
        try { el.innerHTML = marked.parse(rawText); }
        catch (e) { el.textContent = rawText; }
      }
    }

    // --- JSON table rendering (for flat/simple dicts) ---
    function renderJsonTable(elementId, data) {
      var el = document.getElementById(elementId);
      if (!el || !data) return;
      if (typeof data !== 'object' || Array.isArray(data)) {
        el.innerHTML = '<pre>' + JSON.stringify(data, null, 2) + '</pre>';
        return;
      }
      var html = '<table class="json-table">';
      for (var key in data) {
        var val = data[key];
        var display;
        if (val && typeof val === 'object') {
          display = '<details class="json-details"><summary>' + (Array.isArray(val) ? '[' + val.length + ' items]' : '{...}') + '</summary><pre>' + escapeHtml(JSON.stringify(val, null, 2)) + '</pre></details>';
        } else {
          display = '<span class="json-val json-' + typeof val + '">' + escapeHtml(String(val)) + '</span>';
        }
        html += '<tr><td class="json-key">' + escapeHtml(key) + '</td><td>' + display + '</td></tr>';
      }
      html += '</table>';
      el.innerHTML = html;
    }

    function escapeHtml(s) {
      var d = document.createElement('div');
      d.textContent = s;
      return d.innerHTML;
    }

    // --- Render all sections ---
    renderMarkdown('methods-content', METHODS_RAW);
    renderMarkdown('synthesis-content', SYNTHESIS_RAW);
    renderJsonTable('evidence-quality-content', EVIDENCE_QUALITY_DATA);
    renderJsonTable('rubric-content', RUBRIC_DATA);
  </script>
</body>
</html>
